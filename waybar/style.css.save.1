/* Підключаємо кольори від твоїх шпалер (Pywal) */
@import url("/home/sf/.cache/wal/colors-waybar.css");

* {
    font-family: "JetBrainsMono Nerd Font", "Ubuntu", sans-serif;
    font-size: 11px;
    font-weight: bold;
}

/* Сама панель прозора */
window#waybar {
    background-color: transparent;
}

/* --- РОБОЧІ СТОЛИ --- */
#workspaces {
    margin: 4px 4px;
    border-radius: 50px;
    /* 2. Темно-прозорий фон замість суцільного чорного */
    background-color: rgba(0, 0, 0, 0.6); 
    /* 3. Яскравий акцентний колір 2 */
    border: 2px solid @color2; 
    /* 1. Додаємо малесенький відступ всередині контейнера, щоб кнопка не "різала" рамку */
    padding: 2px; 
}

#workspaces button {
    /* 1. Фікс зайвого простору: робимо акуратні симетричні кнопки */
    padding: 0 8px; 
    margin: 0;
    min-width: 24px; /* Робимо їх трішки ширшими для балансу */
    color: @color2; /* Яскравий текст */
    border-radius: 50px;
    transition: all 0.2s ease;
    border: none;
    box-shadow: none; /* Забираємо системні тіні, які робили баг */
}

#workspaces button.active {
    background-color: @color2; /* Яскравий фон для активного вікна */
    color: #000000; /* Чорний текст на яскравому читається найкраще */
}

#workspaces button:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

/* --- ВСІ ІНШІ МОДУЛІ (КАПСУЛИ З ОБВОДКОЮ) --- */
#custom-prev, #custom-next, #mpris, #clock, #language, #battery, #cpu, #memory, #network, #pulseaudio, #tray, #custom-cava {
    padding: 0 15px;
    margin: 4px 4px;
    /* Темно-прозорий фон для всіх модулів */
    background-color: rgba(0, 0, 0, 0.6); 
    border: 2px solid @color2; /* Яскрава обводка */
    color: @color2; /* Яскравий текст/іконки */
    border-radius: 50px; 
}

/* Окремі винятки для плеєра */
#mpris {
    margin-left: 0px;
    margin-right: 0px;
    transition: all 0.3s ease;
}

#mpris.paused {
    border-color: @color8; /* Сірий, коли на паузі */
    color: @color8;
}

#custom-prev {
    margin-right: 4px; 
}

#custom-next {
    margin-left: 4px;  
}

/* Еквалайзер cava */
#custom-cava {
    padding: 0 20px;
    font-size: 16px;
    color: @color2; /* Робимо еквалайзер теж яскравим */
}

